# career_dashboard 서버 환경변수
# 이 파일을 .env 로 복사하고 실제 값을 채워 넣으세요.
# cp .env.example .env

# Gemma API 인증 키 (api.vibemakers.kr)
COMPANY_INSIGHT_API_KEY=여기에_실제_API_KEY_입력
ROLE_RESUME_GUIDE_API_KEY=여기에_실제_API_KEY_입력

# 아래는 기본값과 동일하므로 변경이 필요할 때만 설정
# COMPANY_INSIGHT_BASE_URL=https://api.vibemakers.kr/v1
# COMPANY_INSIGHT_MODEL=gemma-4-31b
# ROLE_RESUME_GUIDE_BASE_URL=https://api.vibemakers.kr/v1
# ROLE_RESUME_GUIDE_MODEL=gemma-4-31b

# 서버 포트 (기본값: 4173)
# CAREER_DASHBOARD_PORT=4180
